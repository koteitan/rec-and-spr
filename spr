#!/bin/sh
# Local English transcription with WhisperX.
set -eu

project_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
version=$(cat "$project_dir/VERSION")

for argument do
    case "$argument" in
        -v|--version)
            printf 'spr %s\n' "$version"
            exit 0
            ;;
    esac
done

whisperx="$project_dir/.venv-whisperx/bin/whisperx"
if [ ! -x "$whisperx" ]; then
    printf '%s\n' \
        'spr: WhisperX is not installed.' \
        'Run: uv venv .venv-whisperx --python 3.10' \
        '     uv pip install --python .venv-whisperx/bin/python -r requirements-whisperx.txt' >&2
    exit 127
fi

# Translate spr's convenience aliases to WhisperX option names. The loop
# rotates the original arguments and appends each normalized argument, keeping
# their order and allowing both "--option value" and "--option=value" forms.
for argument do
    shift
    case "$argument" in
        -h) argument=--help ;;
        --type) argument=--compute_type ;;
        --type=*) argument="--compute_type=${argument#*=}" ;;
        --batcha) argument=--batch_size ;;
        --batcha=*) argument="--batch_size=${argument#*=}" ;;
        --lang) argument=--language ;;
        --lang=*) argument="--language=${argument#*=}" ;;
        --dir) argument=--output_dir ;;
        --dir=*) argument="--output_dir=${argument#*=}" ;;
        --format) argument=--output_format ;;
        --format=*) argument="--output_format=${argument#*=}" ;;
        --no-align) argument=--no_align ;;
    esac
    set -- "$@" "$argument"
done

export HF_HOME="${HF_HOME:-$project_dir/.cache/huggingface}"
export TORCH_HOME="${TORCH_HOME:-$project_dir/.cache/torch}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$project_dir/.cache}"

exec "$whisperx" \
    --model_dir "$project_dir/.models/whisperx" \
    --device "${WHISPERX_DEVICE:-cuda}" \
    --compute_type "${WHISPERX_COMPUTE_TYPE:-float16}" \
    --model "${WHISPERX_MODEL:-medium.en}" \
    --language "${WHISPERX_LANGUAGE:-en}" \
    --batch_size "${WHISPERX_BATCH_SIZE:-4}" \
    "$@"
